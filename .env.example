# Optional: Gemini API (only if you use features that call Google Generative AI).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public base URL for this deployment (callbacks, absolute links if needed).
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_SITE_URL: The public website URL used for canonical links and metadata.
NEXT_PUBLIC_SITE_URL="https://www.yakircohen.com"

# NEXT_PUBLIC_GA_ID: Google Analytics measurement ID for client-side tracking.
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Optional: hosted WebM URL for the home hero backdrop video (keep file small; poster falls back when unset or reduced-motion).
NEXT_PUBLIC_HERO_WEBM_URL=""

# LOGTAIL_SOURCE_TOKEN: Private Logtail source token for server-side logging and webhook events.
LOGTAIL_SOURCE_TOKEN="YOUR_LOGTAIL_SOURCE_TOKEN"

# STEMSPLIT_API_KEY: API key for the StemSplit audio-separation service.
STEMSPLIT_API_KEY="sdddd64e"

